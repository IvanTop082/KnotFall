FROM python:3.12-slim

WORKDIR /app

ENV PYTHONPATH=/app

COPY apps/api/requirements.docker.txt /tmp/requirements.docker.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements.docker.txt

COPY . /app

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
